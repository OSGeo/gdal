# All but gdalinfo
set(PROGRAMS
    gdal
    gdal2tiles.py
    gdal2tiles
    gdal2xyz.py
    gdal2xyz
    gdaladdo
    gdalbuildvrt
    gdal_calc.py
    gdal_calc
    gdalcompare.py
    gdalcompare
    gdal-config
    gdal_contour
    gdaldem
    gdal_edit.py
    gdal_edit
    gdalenhance
    gdal_fillnodata.py
    gdal_fillnodata
    gdal_grid
    gdallocationinfo
    gdalmanage
    gdal_merge.py
    gdal_merge
    gdalmove.py
    gdalmove
    gdal_polygonize.py
    gdal_polygonize
    gdal_proximity.py
    gdal_proximity
    gdal_rasterize
    gdal_retile.py
    gdal_retile
    gdal_sieve.py
    gdal_sieve
    gdalsrsinfo
    gdaltindex
    gdaltransform
    gdal_footprint
    gdal_translate
    gdalwarp
    ogr2ogr
    ogrinfo
    ogrlineref
    ogrmerge.py
    ogrmerge
    ogrtindex
    ogr_layer_algebra.py
    ogr_layer_algebra
    gdal_viewshed
    gdal_create
    sozip)

set(INSTALL_DIR "$ENV{DESTDIR}${CMAKE_INSTALL_PREFIX}/@BASH_COMPLETIONS_DIR@")

file(MAKE_DIRECTORY "${INSTALL_DIR}")
message(STATUS "Installing ${INSTALL_DIR}/gdalinfo")
configure_file("@CMAKE_CURRENT_SOURCE_DIR@/gdal-bash-completion.sh" "${INSTALL_DIR}/gdalinfo" COPYONLY)
file(APPEND "@PROJECT_BINARY_DIR@/install_manifest_extra.txt" "${INSTALL_DIR}/gdalinfo\n")

foreach (program IN LISTS PROGRAMS)
  message(STATUS "Installing ${INSTALL_DIR}/${program}")
  if (NOT CMAKE_HOST_SYSTEM_NAME STREQUAL "Windows")
    execute_process(COMMAND ${CMAKE_COMMAND} -E create_symlink "gdalinfo" "${INSTALL_DIR}/${program}")
  else ()
    configure_file("${INSTALL_DIR}/gdalinfo" "${INSTALL_DIR}/${program}" COPYONLY)
  endif ()
  file(APPEND "@PROJECT_BINARY_DIR@/install_manifest_extra.txt" "${INSTALL_DIR}/${program}\n")
endforeach ()
